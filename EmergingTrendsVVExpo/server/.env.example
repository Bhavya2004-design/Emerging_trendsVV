PORT=8787
# Bind all interfaces so phones on Wi‑Fi / hotspot can reach this machine (default 0.0.0.0).
LISTEN_HOST=0.0.0.0
# Recommended: Cloud Vision (free tier monthly quota; needs GCP project + API key with Vision enabled).
GOOGLE_CLOUD_VISION_API_KEY=
# Optional fashion classifier assist (free HF token). Improves item-type coverage / multi-item ranking.
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=openai/clip-vit-large-patch14-336
# Keep Vision as primary detector by default. Set to 1 only if you want HF to override primary item type.
HUGGINGFACE_ENABLE_PRIMARY_OVERRIDE=0
# Fallback when Vision key is unset: openai | stub (stub returns a valid “unconfigured” envelope).
AI_MODE=stub
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
MAX_IMAGE_BYTES=8000000
AI_SERVER_API_KEY=vv-local-dev-key
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20
